# Telegram Bot
BOT_TOKEN=your_bot_token_from_botfather

# Mini App URL (set in BotFather → Web App URL)
WEBAPP_URL=https://your-domain.com

# PostgreSQL
DATABASE_URL=postgresql://brainify:brainify@localhost:5432/brainify
POSTGRES_USER=brainify
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=brainify

# Redis
REDIS_URL=redis://localhost:6379

# API
API_HOST=0.0.0.0
API_PORT=3000

# Internal API secret (shared between bot and API)
INTERNAL_API_SECRET=change_me_to_random_secret

# Telegram Payments
PAYMENT_PROVIDER_TOKEN=your_payment_provider_token

# JWT (web auth via Telegram Login Widget)
JWT_SECRET=change_me_to_random_secret_min_32_chars
JWT_EXPIRY=1h

# Webapp bot username (for subscribe button)
VITE_BOT_USERNAME=BrainifyBot

# Logging
LOG_LEVEL=info

# Environment
NODE_ENV=development
